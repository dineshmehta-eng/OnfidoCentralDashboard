# Application
APP_NAME=Onfido_SQL_Dashboard
APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8000

# SQL Server connection
SQL_SERVER=YOUR_SERVER_NAME_OR_IP
SQL_DATABASE=Onfido_DB
SQL_USERNAME=sa
SQL_PASSWORD=YOUR_STRONG_PASSWORD_HERE
SQL_DRIVER=ODBC Driver 17 for SQL Server
SQL_TRUST_CERTIFICATE=yes
SQL_ENCRYPT=no
SQL_TRUSTED_CONNECTION=no
SQL_POOL_SIZE=20
SQL_MAX_OVERFLOW=40
SQL_POOL_RECYCLE=1800

# CORS (comma-separated list of allowed frontend origins)
API_CORS_ORIGINS=*

# Caching (seconds)
CACHE_TTL_SECONDS=300

# Logging: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Optional API key auth (leave empty to disable)
API_KEY=

# Mock mode: set to "true" for local UI testing without SQL Server
MOCK_DB=false

# ETL (only needed if running the hourly sync in this project)
GOOGLE_SERVICE_ACCOUNT_FILE=config/service_account.json
ETL_SYNC_INTERVAL_MINUTES=60
ETL_SYNC_TABLES=stg_doc_etm,stg_doc_task_skip,stg_poa_etm
# Optional: use JSON text instead of a file for scheduled ETL auth.
# GOOGLE_SERVICE_ACCOUNT_JSON=
