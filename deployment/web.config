<?xml version="1.0" encoding="utf-8"?>
<!--
  IIS URL Rewrite + ARR Reverse Proxy for Onfido Dashboard
  Requirements:
    - IIS URL Rewrite Module 2.1+ (https://www.iis.net/downloads/microsoft/url-rewrite)
    - IIS Application Request Routing 3.0+ (https://www.iis.net/downloads/microsoft/application-request-routing)
    - In IIS Manager > ARR > Server Proxy Settings: Enable proxy
  Place this file in the root of your IIS site (e.g., C:\inetpub\wwwroot\onfido\web.config).
  All requests are forwarded to the Uvicorn backend on localhost:8000.
-->
<configuration>
  <system.webServer>
    <rewrite>
      <rules>
        <!-- Reverse proxy everything to the FastAPI backend -->
        <rule name="ReverseProxyToOnfidoAPI" stopProcessing="true">
          <match url="^(.*)$" />
          <conditions>
            <add input="{CACHE_URL}" pattern="^(.+)://" />
          </conditions>
          <action type="Rewrite" url="http://localhost:8000/{R:1}" />
        </rule>
      </rules>
      <outboundRules>
        <rule name="RewriteLocationHeader" preCondition="ResponseIsRedirect">
          <match serverVariable="RESPONSE_Location" pattern="^http://localhost:8000/(.*)" />
          <action type="Rewrite" value="{C:1}://{HTTP_HOST}/{R:1}" />
        </rule>
        <preConditions>
          <preCondition name="ResponseIsRedirect">
            <add input="{RESPONSE_STATUS}" pattern="^301|302|307" />
          </preCondition>
        </preConditions>
      </outboundRules>
    </rewrite>

    <!-- Show a friendly maintenance page when the backend is down -->
    <httpErrors errorMode="Custom">
      <remove statusCode="502" />
      <error statusCode="502" path="maintenance.html" responseMode="File" />
      <remove statusCode="503" />
      <error statusCode="503" path="maintenance.html" responseMode="File" />
    </httpErrors>

    <!-- Allow large JSON payloads from the dashboard -->
    <security>
      <requestFiltering>
        <requestLimits maxAllowedContentLength="100000000" />
      </requestFiltering>
    </security>
  </system.webServer>
</configuration>
